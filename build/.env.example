# Local build-only configuration for TimeCapsuleSMB.
# Copy to build/.env when working on the NetBSD cross-build flow.

# Wrappers select these lanes automatically:
#   ./build/download.sh           -> SDK_FAMILY=netbsd7
#   ./build/bootstrap.sh          -> SDK_FAMILY=netbsd7
#   ./build/downloadoldle.sh      -> SDK_FAMILY=netbsd4, NETBSD4_ABI=le
#   ./build/downloadoldbe.sh      -> SDK_FAMILY=netbsd4, NETBSD4_ABI=be
#   ./build/bootstrapoldle.sh     -> SDK_FAMILY=netbsd4, NETBSD4_ABI=le
#   ./build/bootstrapoldbe.sh     -> SDK_FAMILY=netbsd4, NETBSD4_ABI=be
#   ./build/downloadsamba4.sh     -> SDK_FAMILY=netbsd7, DEVICE_FAMILY=new, SAMBA_FAMILY=samba4
#   ./build/samba4.sh             -> SDK_FAMILY=netbsd7, DEVICE_FAMILY=new, SAMBA_FAMILY=samba4
#   ./build/downloadsamba3oldle.sh -> SDK_FAMILY=netbsd4, DEVICE_FAMILY=old, SAMBA_FAMILY=samba3, NETBSD4_ABI=le
#   ./build/downloadsamba3oldbe.sh -> SDK_FAMILY=netbsd4, DEVICE_FAMILY=old, SAMBA_FAMILY=samba3, NETBSD4_ABI=be
#   ./build/downloadsamba4oldle.sh -> SDK_FAMILY=netbsd4, DEVICE_FAMILY=old, SAMBA_FAMILY=samba4, NETBSD4_ABI=le
#   ./build/downloadsamba4oldbe.sh -> SDK_FAMILY=netbsd4, DEVICE_FAMILY=old, SAMBA_FAMILY=samba4, NETBSD4_ABI=be
#   ./build/samba3oldle.sh        -> SDK_FAMILY=netbsd4, DEVICE_FAMILY=old, SAMBA_FAMILY=samba3, NETBSD4_ABI=le
#   ./build/samba3oldbe.sh        -> SDK_FAMILY=netbsd4, DEVICE_FAMILY=old, SAMBA_FAMILY=samba3, NETBSD4_ABI=be
#   ./build/samba4oldle.sh        -> SDK_FAMILY=netbsd4, DEVICE_FAMILY=old, SAMBA_FAMILY=samba4, NETBSD4_ABI=le
#   ./build/samba4oldbe.sh        -> SDK_FAMILY=netbsd4, DEVICE_FAMILY=old, SAMBA_FAMILY=samba4, NETBSD4_ABI=be

# NetBSD SDK roots on the VM
NETBSD4LE_ROOT='/root/netbsd4'
NETBSD4LE_SRC='/root/netbsd4/usr/src'
NETBSD4LE_OUT='/root/tc-earmv4-netbsd4'
NETBSD4BE_ROOT='/root/netbsd4'
NETBSD4BE_SRC='/root/netbsd4/usr/src'
NETBSD4BE_OUT='/root/tc-armeb-netbsd4'
NETBSD7_ROOT='/root/netbsd7'
NETBSD7_SRC='/root/netbsd7/usr/src'
NETBSD7_OUT='/root/tc-earmv4-netbsd7'

# Optional explicit log paths for SDK setup
NETBSD4LE_DOWNLOAD_LOG='/root/tc-earmv4-netbsd4/download.log'
NETBSD4LE_TOOLS_LOG='/root/tc-earmv4-netbsd4/bootstrap-tools.log'
NETBSD4LE_DISTRIBUTION_LOG='/root/tc-earmv4-netbsd4/bootstrap-distribution.log'
NETBSD4BE_DOWNLOAD_LOG='/root/tc-armeb-netbsd4/download.log'
NETBSD4BE_TOOLS_LOG='/root/tc-armeb-netbsd4/bootstrap-tools.log'
NETBSD4BE_DISTRIBUTION_LOG='/root/tc-armeb-netbsd4/bootstrap-distribution.log'
NETBSD7_DOWNLOAD_LOG='/root/tc-earmv4-netbsd7/download.log'
NETBSD7_TOOLS_LOG='/root/tc-earmv4-netbsd7/bootstrap-tools.log'
NETBSD7_DISTRIBUTION_LOG='/root/tc-earmv4-netbsd7/bootstrap-distribution.log'

# Host toolchain paths on the VM
HOST_CC='/usr/pkg/gcc7/bin/gcc'
HOST_CXX='/usr/pkg/gcc7/bin/g++'
HOST_CFLAGS='-O -fcommon -fgnu89-inline'
HOST_CXXFLAGS='-O -fcommon -fgnu89-inline'
HOST_CPPFLAGS='-D__GNUC_GNU_INLINE__'
NO_PTHREADS='1'

# Samba 4 netbsd7 lane
SAMBA4_VERSION='4.8.12'
SAMBA4_GIT_URL='https://github.com/samba-team/samba.git'
SAMBA4_GIT_REF='samba-4.8.12'
SAMBA4_NETBSD7_WORK='/root/tc-samba4-netbsd7'
SAMBA4_NETBSD7_SRC_DIR='/root/tc-samba4-netbsd7/samba'
SAMBA4_NETBSD7_STAGE='/root/tc-netbsd7'
SAMBA4_NETBSD7_BUILD='/root/tc-samba4-netbsd7/build'
SAMBA4_NETBSD7_DOWNLOAD_LOG='/root/tc-earmv4-netbsd7/downloadsamba4.log'
SAMBA4_NETBSD7_LOG='/root/tc-earmv4-netbsd7/samba4.log'
SAMBA4_JOBS='2'

# Samba 3 netbsd4 lane
SAMBA3_VERSION='3.6.25'
SAMBA3_TARBALL_URL='https://download.samba.org/pub/samba/stable/samba-3.6.25.tar.gz'
SAMBA3_NETBSD4LE_WORK='/root/tc-samba3-netbsd4le'
SAMBA3_NETBSD4LE_SRC_DIR='/root/tc-samba3-netbsd4le/samba-3.6.25'
SAMBA3_NETBSD4LE_STAGE='/root/tc-netbsd4le'
SAMBA3_NETBSD4LE_BUILD='/root/tc-samba3-netbsd4le/build'
SAMBA3_NETBSD4LE_DOWNLOAD_LOG='/root/tc-earmv4-netbsd4/downloadsamba3old.log'
SAMBA3_NETBSD4LE_LOG='/root/tc-earmv4-netbsd4/samba3old.log'
SAMBA3_NETBSD4BE_WORK='/root/tc-samba3-netbsd4be'
SAMBA3_NETBSD4BE_SRC_DIR='/root/tc-samba3-netbsd4be/samba-3.6.25'
SAMBA3_NETBSD4BE_STAGE='/root/tc-netbsd4be'
SAMBA3_NETBSD4BE_BUILD='/root/tc-samba3-netbsd4be/build'
SAMBA3_NETBSD4BE_DOWNLOAD_LOG='/root/tc-armeb-netbsd4/downloadsamba3old.log'
SAMBA3_NETBSD4BE_LOG='/root/tc-armeb-netbsd4/samba3old.log'
SAMBA3_JOBS='2'

# Future Samba 4 netbsd4 lane
SAMBA4_NETBSD4LE_WORK='/root/tc-samba4-netbsd4le'
SAMBA4_NETBSD4LE_SRC_DIR='/root/tc-samba4-netbsd4le/samba'
SAMBA4_NETBSD4LE_STAGE='/root/tc-netbsd4le'
SAMBA4_NETBSD4LE_BUILD='/root/tc-samba4-netbsd4le/build'
SAMBA4_NETBSD4LE_DOWNLOAD_LOG='/root/tc-earmv4-netbsd4/downloadsamba4old.log'
SAMBA4_NETBSD4LE_LOG='/root/tc-earmv4-netbsd4/samba4old.log'
SAMBA4_NETBSD4BE_WORK='/root/tc-samba4-netbsd4be'
SAMBA4_NETBSD4BE_SRC_DIR='/root/tc-samba4-netbsd4be/samba'
SAMBA4_NETBSD4BE_STAGE='/root/tc-netbsd4be'
SAMBA4_NETBSD4BE_BUILD='/root/tc-samba4-netbsd4be/build'
SAMBA4_NETBSD4BE_DOWNLOAD_LOG='/root/tc-armeb-netbsd4/downloadsamba4old.log'
SAMBA4_NETBSD4BE_LOG='/root/tc-armeb-netbsd4/samba4old.log'

# mDNS / NBNS helper outputs
MDNS_STAGE_NETBSD7='/root/tc-netbsd7'
NBNS_STAGE_NETBSD7='/root/tc-netbsd7'
MDNS_STAGE_NETBSD4LE='/root/tc-netbsd4le'
NBNS_STAGE_NETBSD4LE='/root/tc-netbsd4le'
MDNS_STAGE_NETBSD4BE='/root/tc-netbsd4be'
NBNS_STAGE_NETBSD4BE='/root/tc-netbsd4be'
MDNS_BIN_NAME='mdns-advertiser'
NBNS_BIN_NAME='nbns-advertiser'

# Samba 4 cross-exec scratch space
SAMBA4_CROSS_EXEC_TMP_NETBSD7='/tmp/tc-samba-probes-netbsd7'
SAMBA4_CROSS_EXEC_TMP_NETBSD4LE='/mnt/Memory/tc-samba-probes-netbsd4le'
SAMBA4_CROSS_EXEC_TMP_NETBSD4BE='/mnt/Memory/tc-samba-probes-netbsd4be'

# NetBSD 7 / NetBSD 6-generation Time Capsule connection
TC_NETBSD7_HOST='root@192.168.1.217'
TC_NETBSD7_SSH_OPTS='-o HostKeyAlgorithms=+ssh-rsa -o PubkeyAcceptedAlgorithms=+ssh-rsa -o KexAlgorithms=+diffie-hellman-group14-sha1'
TC_NETBSD7_SSH_PROXYCOMMAND=''
TC_NETBSD7_PASSWORD=''
TC_NETBSD7_NET_IFACE='bridge0'
TC_NETBSD7_SHARE_NAME='Data'
TC_NETBSD7_NETBIOS_NAME='TimeCapsule'
TC_NETBSD7_PAYLOAD_DIR_NAME='samba4'
TC_NETBSD7_CIFS_COMMENT='James AirPort Time Capsule'
TC_NETBSD7_CIFS_SYSDNSNAME='James AirPort Time Capsule'
TC_NETBSD7_CIFS_VOLUME_NAME='AirPort Disk'

# NetBSD 4 little-endian Time Capsule connection
TC_NETBSD4LE_HOST='root@timecapsule.local'
TC_NETBSD4LE_SSH_OPTS='-o HostKeyAlgorithms=+ssh-rsa -o PubkeyAcceptedAlgorithms=+ssh-rsa -o KexAlgorithms=+diffie-hellman-group14-sha1 -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'
TC_NETBSD4LE_SSH_PROXYCOMMAND=''
TC_NETBSD4LE_PASSWORD=''
TC_NETBSD4LE_NET_IFACE='bridge0'
TC_NETBSD4LE_SHARE_NAME='Data'
TC_NETBSD4LE_NETBIOS_NAME='TimeCapsule'
TC_NETBSD4LE_PAYLOAD_DIR_NAME='samba4'
TC_NETBSD4LE_CIFS_COMMENT='James AirPort Time Capsule'
TC_NETBSD4LE_CIFS_SYSDNSNAME='James AirPort Time Capsule'
TC_NETBSD4LE_CIFS_VOLUME_NAME='AirPort Disk'

# NetBSD 4 big-endian Time Capsule connection
TC_NETBSD4BE_HOST='root@timecapsule.local'
TC_NETBSD4BE_SSH_OPTS='-o HostKeyAlgorithms=+ssh-rsa -o PubkeyAcceptedAlgorithms=+ssh-rsa -o KexAlgorithms=+diffie-hellman-group14-sha1 -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'
TC_NETBSD4BE_SSH_PROXYCOMMAND=''
TC_NETBSD4BE_PASSWORD=''
TC_NETBSD4BE_NET_IFACE='bridge0'
TC_NETBSD4BE_SHARE_NAME='Data'
TC_NETBSD4BE_NETBIOS_NAME='TimeCapsule'
TC_NETBSD4BE_PAYLOAD_DIR_NAME='samba4'
TC_NETBSD4BE_CIFS_COMMENT='James AirPort Time Capsule'
TC_NETBSD4BE_CIFS_SYSDNSNAME='James AirPort Time Capsule'
TC_NETBSD4BE_CIFS_VOLUME_NAME='AirPort Disk'
