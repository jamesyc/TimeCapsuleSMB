# Local build-only configuration for TimeCapsuleSMB.
# Copy to build/.env when working on the NetBSD cross-build flow.

# Wrappers select these lanes automatically:
#   ./build/download.sh           -> SDK_FAMILY=netbsd7
#   ./build/bootstrap.sh          -> SDK_FAMILY=netbsd7
#   ./build/downloadold.sh        -> SDK_FAMILY=netbsd4
#   ./build/bootstrapold.sh       -> SDK_FAMILY=netbsd4
#   ./build/downloadsamba4.sh     -> SDK_FAMILY=netbsd7, DEVICE_FAMILY=new, SAMBA_FAMILY=samba4
#   ./build/samba4.sh             -> SDK_FAMILY=netbsd7, DEVICE_FAMILY=new, SAMBA_FAMILY=samba4
#   ./build/downloadsamba3old.sh  -> SDK_FAMILY=netbsd4, DEVICE_FAMILY=old, SAMBA_FAMILY=samba3
#   ./build/samba3old.sh          -> SDK_FAMILY=netbsd4, DEVICE_FAMILY=old, SAMBA_FAMILY=samba3

# NetBSD SDK roots on the VM
NETBSD4_ROOT='/root/netbsd4'
NETBSD4_SRC='/root/netbsd4/usr/src'
NETBSD4_OUT='/root/tc-earmv4-netbsd4'
NETBSD7_ROOT='/root/netbsd7'
NETBSD7_SRC='/root/netbsd7/usr/src'
NETBSD7_OUT='/root/tc-earmv4-netbsd7'

# Optional explicit log paths for SDK setup
NETBSD4_DOWNLOAD_LOG='/root/tc-earmv4-netbsd4/download.log'
NETBSD4_TOOLS_LOG='/root/tc-earmv4-netbsd4/bootstrap-tools.log'
NETBSD4_DISTRIBUTION_LOG='/root/tc-earmv4-netbsd4/bootstrap-distribution.log'
NETBSD7_DOWNLOAD_LOG='/root/tc-earmv4-netbsd7/download.log'
NETBSD7_TOOLS_LOG='/root/tc-earmv4-netbsd7/bootstrap-tools.log'
NETBSD7_DISTRIBUTION_LOG='/root/tc-earmv4-netbsd7/bootstrap-distribution.log'

# Host toolchain paths on the VM
HOST_CC='/usr/pkg/gcc7/bin/gcc'
HOST_CXX='/usr/pkg/gcc7/bin/g++'
HOST_CFLAGS='-O -fcommon -fgnu89-inline'
HOST_CXXFLAGS='-O -fcommon -fgnu89-inline'
HOST_CPPFLAGS='-D__GNUC_GNU_INLINE__'
NO_PTHREADS='1'

# Samba 4 netbsd7 lane
SAMBA4_VERSION='4.8.12'
SAMBA4_GIT_URL='https://github.com/samba-team/samba.git'
SAMBA4_GIT_REF='samba-4.8.12'
SAMBA4_NETBSD7_WORK='/root/tc-samba4-netbsd7'
SAMBA4_NETBSD7_SRC_DIR='/root/tc-samba4-netbsd7/samba'
SAMBA4_NETBSD7_STAGE='/root/tc-netbsd7'
SAMBA4_NETBSD7_BUILD='/root/tc-samba4-netbsd7/build'
SAMBA4_NETBSD7_DOWNLOAD_LOG='/root/tc-earmv4-netbsd7/downloadsamba4.log'
SAMBA4_NETBSD7_LOG='/root/tc-earmv4-netbsd7/samba4.log'
SAMBA4_JOBS='2'

# Samba 3 netbsd4 lane
SAMBA3_VERSION='3.6.25'
SAMBA3_TARBALL_URL='https://download.samba.org/pub/samba/stable/samba-3.6.25.tar.gz'
SAMBA3_NETBSD4_WORK='/root/tc-samba3-netbsd4'
SAMBA3_NETBSD4_SRC_DIR='/root/tc-samba3-netbsd4/samba-3.6.25'
SAMBA3_NETBSD4_STAGE='/root/tc-netbsd4'
SAMBA3_NETBSD4_BUILD='/root/tc-samba3-netbsd4/build'
SAMBA3_NETBSD4_DOWNLOAD_LOG='/root/tc-earmv4-netbsd4/downloadsamba3old.log'
SAMBA3_NETBSD4_LOG='/root/tc-earmv4-netbsd4/samba3old.log'
SAMBA3_JOBS='2'

# Future Samba 4 netbsd4 lane
SAMBA4_NETBSD4_WORK='/root/tc-samba4-netbsd4'
SAMBA4_NETBSD4_SRC_DIR='/root/tc-samba4-netbsd4/samba'
SAMBA4_NETBSD4_STAGE='/root/tc-netbsd4'
SAMBA4_NETBSD4_BUILD='/root/tc-samba4-netbsd4/build'
SAMBA4_NETBSD4_DOWNLOAD_LOG='/root/tc-earmv4-netbsd4/downloadsamba4old.log'
SAMBA4_NETBSD4_LOG='/root/tc-earmv4-netbsd4/samba4old.log'

# mDNS / NBNS helper outputs
MDNS_STAGE_NETBSD7='/root/tc-netbsd7'
NBNS_STAGE_NETBSD7='/root/tc-netbsd7'
MDNS_STAGE_NETBSD4='/root/tc-netbsd4'
NBNS_STAGE_NETBSD4='/root/tc-netbsd4'
MDNS_BIN_NAME='mdns-advertiser'
NBNS_BIN_NAME='nbns-advertiser'

# Samba 4 cross-exec scratch space
SAMBA4_CROSS_EXEC_TMP_NETBSD7='/tmp/tc-samba-probes-netbsd7'
SAMBA4_CROSS_EXEC_TMP_NETBSD4='/mnt/Memory/tc-samba-probes-netbsd4'

# Newer Time Capsule connection
TC_NEW_HOST='root@192.168.1.217'
TC_NEW_SSH_OPTS='-o HostKeyAlgorithms=+ssh-rsa -o PubkeyAcceptedAlgorithms=+ssh-rsa -o KexAlgorithms=+diffie-hellman-group14-sha1'
TC_NEW_SSH_PROXYCOMMAND=''
TC_NEW_PASSWORD=''

# Older NetBSD 4 Time Capsule connection
TC_OLD_HOST='root@timecapsule.local'
TC_OLD_SSH_OPTS='-o HostKeyAlgorithms=+ssh-rsa -o PubkeyAcceptedAlgorithms=+ssh-rsa -o KexAlgorithms=+diffie-hellman-group14-sha1 -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'
TC_OLD_SSH_PROXYCOMMAND=''
TC_OLD_PASSWORD=''
