# Local build-only configuration for TimeCapsuleSMB.
# Copy to build/.env when working on the NetBSD cross-build flow.

# Active build lane. The wrappers set this automatically:
#   ./build/download.sh      -> netbsd7
#   ./build/bootstrap.sh     -> netbsd7
#   ./build/downloadold.sh   -> netbsd4
#   ./build/bootstrapold.sh  -> netbsd4
BUILD_TARGET='netbsd7'
BUILD_MACHINE='evbarm'
BUILD_MACHINE_ARCH='earmv4'

# NetBSD build roots on the VM
NETBSD4_ROOT='/root/netbsd4'
NETBSD6_ROOT='/root/netbsd6'
NETBSD7_ROOT='/root/netbsd7'
NETBSD4_SRC='/root/netbsd4/usr/src'
NETBSD7_SRC='/root/netbsd7/usr/src'
NETBSD4_OUT='/root/tc-earmv4-netbsd4'
NETBSD7_OUT='/root/tc-earmv4'

# Host toolchain paths on the VM
HOST_CC='/usr/pkg/gcc7/bin/gcc'
HOST_CXX='/usr/pkg/gcc7/bin/g++'
HOST_CFLAGS='-O -fcommon -fgnu89-inline'
HOST_CXXFLAGS='-O -fcommon -fgnu89-inline'
HOST_CPPFLAGS='-D__GNUC_GNU_INLINE__'
NO_PTHREADS='1'

# Samba build settings
SAMBA4_VERSION='4.8.12'
SAMBA4_GIT_URL='https://github.com/samba-team/samba.git'
SAMBA4_GIT_REF='samba-4.8.12'
SAMBA4_WORK='/root/tc-samba4'
SAMBA4_SRC_DIR='/root/tc-samba4/samba-4.8.12'
SAMBA4_STAGE='/root/tc-stage4'
SAMBA4_BUILD='/root/tc-samba4/build'
SAMBA4_JOBS='2'
SAMBA4_HOST_ALIAS='armv4-unknown-netbsd7.2'

SAMBA3_VERSION='3.6.25'
SAMBA3_TARBALL_URL='https://download.samba.org/pub/samba/stable/samba-3.6.25.tar.gz'
SAMBA3_GIT_URL='https://github.com/samba-team/samba.git'
SAMBA3_GIT_REF='samba-3.6.25'
SAMBA3_WORK='/root/tc-samba3'
SAMBA3_SRC_DIR='/root/tc-samba3/samba-3.6.25'
SAMBA3_STAGE='/root/tc-stage3'
SAMBA3_BUILD='/root/tc-samba3/build'
SAMBA3_JOBS='2'
SAMBA3_HOST_ALIAS='armv4-unknown-netbsd7.2'

# mDNS advertiser build settings
MDNS_STAGE='/root/tc-stage-mdns'
MDNS_BIN_NAME='mdns-smbd-advertiser'
NBNS_STAGE='/root/tc-stage-nbns'
NBNS_BIN_NAME='nbns-advertiser'

# Time Capsule target for cross-exec and probes
TC_HOST='root@192.168.1.217'
TC_SSH_OPTS='-o HostKeyAlgorithms=+ssh-rsa -o PubkeyAcceptedAlgorithms=+ssh-rsa -o KexAlgorithms=+diffie-hellman-group14-sha1'
TC_SSH_PROXYCOMMAND=''

# Time Capsule root password used by the cross-exec wrapper on the VM.
TC_PASSWORD=''
