 }
 
 static void talloc_stackframe_init(void)
@@ -159,6 +161,47 @@ static struct talloc_stackframe *talloc_stackframe_get(void)
 	return ts;
 }
 
+void talloc_stackframe_reinit_after_fork(void)
+{
+#ifndef HAVE_PTHREAD
+	/*
+	 * The appliance build intentionally removes pthread support. In that
+	 * mode Samba stores the talloc stack in process-global state instead
+	 * of thread-local state. A forked smbd child inherits a copy of the
+	 * parent's active event-loop stackframes, and freeing those copied
+	 * frames in the child can run parent-side destructors in the wrong
+	 * process.
+	 *
+	 * Drop only the stack tracking. The copied parent allocations are
+	 * process-private after fork and will be reclaimed when the child
+	 * exits. The child will create its own first stackframe when normal
+	 * request handling starts.
+	 */
+	global_ts = NULL;
+#endif
+}
+
+void talloc_stackframe_cleanup_for_exit(void)
+{
+#ifndef HAVE_PTHREAD
+	struct talloc_stackframe *ts = global_ts;
+
+	if (ts == NULL) {
+		return;
+	}
+
+	/*
+	 * Normal smbd shutdown can happen from inside a tevent callback, before
+	 * the matching AFTER_LOOP_ONCE trace hook frees the active stackframe.
+	 * The process is exiting, so avoid running late destructors here; just
+	 * disarm the no-pthread atexit diagnostic for these intentional
+	 * process-exit frames. Abnormal exits still skip this path and keep the
+	 * diagnostic breadcrumbs.
+	 */
+	ts->talloc_stacksize = 0;
+#endif
+}
+
 static int talloc_pop(TALLOC_CTX *frame)
 {
 	struct talloc_stackframe *ts = talloc_stackframe_get_existing();
