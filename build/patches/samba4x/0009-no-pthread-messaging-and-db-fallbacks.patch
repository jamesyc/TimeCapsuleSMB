diff --git a/source3/smbd/smbXsrv_client.c b/source3/smbd/smbXsrv_client.c
index fc79672..f60e32c 100644
--- a/source3/smbd/smbXsrv_client.c
+++ b/source3/smbd/smbXsrv_client.c
@@ -85,11 +85,22 @@ NTSTATUS smbXsrv_client_global_init(void)
 		return status;
 	}
 
+#ifdef HAVE_PTHREAD
 	db_ctx = db_open_watched(NULL, &backend, global_messaging_context());
 	if (db_ctx == NULL) {
 		TALLOC_FREE(backend);
 		return NT_STATUS_NO_MEMORY;
 	}
+#else
+	/*
+	 * db_open_watched() adds messaging-based invalidation around the TDB.
+	 * The static Time Capsule build has no pthread support and has already
+	 * disabled the messaging datagram pthreadpool; keep the plain locked TDB
+	 * backend so smbd can start without entering the watched-db reader path.
+	 */
+	db_ctx = backend;
+	backend = NULL;
+#endif
 
 	smbXsrv_client_global_db_ctx = db_ctx;
 
diff --git a/source3/smbd/smbXsrv_session.c b/source3/smbd/smbXsrv_session.c
index a268c3f..f995c45 100644
--- a/source3/smbd/smbXsrv_session.c
+++ b/source3/smbd/smbXsrv_session.c
@@ -90,11 +90,22 @@ NTSTATUS smbXsrv_session_global_init(struct messaging_context *msg_ctx)
 		return status;
 	}
 
+#ifdef HAVE_PTHREAD
 	db_ctx = db_open_watched(NULL, &backend, global_messaging_context());
 	if (db_ctx == NULL) {
 		TALLOC_FREE(backend);
 		return NT_STATUS_NO_MEMORY;
 	}
+#else
+	/*
+	 * db_open_watched() relies on Samba messaging filtered readers for cache
+	 * invalidation. In the no-pthread appliance build, that path can abort
+	 * during smbd startup; a normal locked TDB is enough for this single-node
+	 * file server and preserves the actual session database operations.
+	 */
+	db_ctx = backend;
+	backend = NULL;
+#endif
 
 	smbXsrv_session_global_db_ctx = db_ctx;
 
