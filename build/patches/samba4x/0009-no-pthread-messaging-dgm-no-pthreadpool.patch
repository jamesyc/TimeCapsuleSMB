diff --git a/lib/messaging/messages_dgm.c b/lib/messaging/messages_dgm.c
index 1c96b2f..20b6884 100644
--- a/lib/messaging/messages_dgm.c
+++ b/lib/messaging/messages_dgm.c
@@ -528,6 +528,18 @@ static void messaging_dgm_out_queue_trigger(struct tevent_req *req,
 
 	tevent_req_reset_endtime(req);
 
+#ifndef HAVE_PTHREAD
+	/*
+	 * The Time Capsule appliance binary is a static no-pthread smbd.
+	 * The queued datagram path is only for full sockets and depends on
+	 * pthreadpool_tevent. Do not enter that path without pthreads; the
+	 * direct nonblocking send path below is enough for normal small
+	 * Samba control datagrams, and a full socket should fail cleanly.
+	 */
+	tevent_req_error(req, ENOSYS);
+	return;
+#endif
+
 	state->subreq = pthreadpool_tevent_job_send(
 		state, state->ev, state->pool,
 		messaging_dgm_out_threaded_job, state);
@@ -669,6 +681,17 @@ static int messaging_dgm_out_send_fragment(
 		}
 	}
 
+#ifndef HAVE_PTHREAD
+	/*
+	 * Without pthread support there is no safe background sender for a
+	 * full datagram socket. Return a real send error instead of creating
+	 * a pthreadpool-backed queue that registers atfork handlers and aborts
+	 * in smbd helper children on the appliance.
+	 */
+	DBG_WARNING("messaging datagram send queue unavailable without pthreads\n");
+	return EWOULDBLOCK;
+#endif
+
 	req = messaging_dgm_out_queue_send(out, ev, out, iov, iovlen,
 					   fds, num_fds);
 	if (req == NULL) {
@@ -1079,6 +1102,7 @@ int messaging_dgm_init(struct tevent_context *ev,
 
 	ctx->have_dgm_context = &have_dgm_context;
 
+#ifdef HAVE_PTHREAD
 	ret = pthreadpool_tevent_init(ctx, UINT_MAX, &ctx->pool);
 	if (ret != 0) {
 		DBG_WARNING("pthreadpool_tevent_init failed: %s\n",
@@ -1086,6 +1110,15 @@ int messaging_dgm_init(struct tevent_context *ev,
 		TALLOC_FREE(ctx);
 		return ret;
 	}
+#else
+	/*
+	 * NetBSD Time Capsule targets run the static smbd without libpthread.
+	 * Keep datagram messaging usable via direct nonblocking sends, but do
+	 * not initialize pthreadpool_tevent: its atfork/assert paths are not
+	 * valid in this build and kill notifyd/client children with SIGABRT.
+	 */
+	ctx->pool = NULL;
+#endif
 
 	global_dgm_context = ctx;
 	return 0;
