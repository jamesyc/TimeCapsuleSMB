diff --git a/source3/smbd/smb2_query_directory.c b/source3/smbd/smb2_query_directory.c
--- a/source3/smbd/smb2_query_directory.c
+++ b/source3/smbd/smb2_query_directory.c
@@ -283,6 +283,22 @@ static struct tevent_req *smbd_smb2_query_directory_send(TALLOC_CTX *mem_ctx,
 	}
 
 	if (!fsp->fsp_flags.is_directory) {
+#ifdef TC_SAMBA4X_NETBSD4_COMPAT
+		/*
+		 * NetBSD4 Time Capsule builds can reach SMB2 QUERY_DIRECTORY
+		 * with a directory handle whose cached is_directory flag has
+		 * been lost. Trust stat when it still says directory; otherwise
+		 * let the later directory open and enumeration path decide
+		 * instead of failing on the stale flag.
+		 */
+		if (fsp->fsp_name != NULL &&
+		    S_ISDIR(fsp->fsp_name->st.st_ex_mode))
+		{
+			fsp->fsp_flags.is_directory = true;
+		}
+	}
+	if (!fsp->fsp_flags.is_directory) {
+#endif
 		tevent_req_nterror(req, NT_STATUS_NOT_SUPPORTED);
 		return tevent_req_post(req, ev);
 	}
