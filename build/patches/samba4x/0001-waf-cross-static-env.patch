+def APPLY_HOSTCC_ENV(bld, taskgen):
+    if not getattr(taskgen, 'samba_use_hostcc', False):
+        return
+    if not bld.env.HOSTCC:
+        return
+    taskgen.env = taskgen.env.derive()
+    hostcc = TO_LIST(bld.env.HOSTCC)
+    gccdeps_cflags = [flag for flag in TO_LIST(bld.env.CFLAGS) if flag in ('-MD', '-MMD')]
+    host_cflags = TO_LIST(bld.env.HOST_CFLAGS) + gccdeps_cflags
+    taskgen.env.CC = hostcc
+    taskgen.env.LINK_CC = hostcc
+    taskgen.env.CFLAGS = host_cflags
+    taskgen.env.CPPFLAGS = TO_LIST(bld.env.HOST_CPPFLAGS)
+    taskgen.env.LDFLAGS = []
+    taskgen.env.LINKFLAGS = []
+    taskgen.env.STLIB_MARKER = []
+    taskgen.env.SHLIB_MARKER = []
+    taskgen.env.FULLSTATIC_MARKER = []
+    taskgen.env.EXTRA_CFLAGS = host_cflags
+    taskgen.env.EXTRA_LDFLAGS = []
+
+
