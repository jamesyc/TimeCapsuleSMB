diff --git a/source3/rpc_server/rpc_worker.c b/source3/rpc_server/rpc_worker.c
index 2adcd5c2140..26f0bdb74f2 100644
--- a/source3/rpc_server/rpc_worker.c
+++ b/source3/rpc_server/rpc_worker.c
@@ -1066,10 +1066,21 @@ int rpc_worker_main(
 		const struct ndr_interface_table **ifaces = NULL;
 		size_t num_ifaces;
 
+#ifdef HAVE_PTHREAD
 		num_workers = lp_parm_int(
 			-1, daemon_config_name, "num_workers", num_workers);
 		idle_seconds = lp_parm_int(
 			-1, daemon_config_name, "idle_seconds", idle_seconds);
+#else
+		/*
+		 * samba-dcerpcd probes rpcd_* helpers with --list-interfaces
+		 * before it can create named-pipe sockets. On the static
+		 * no-pthread Time Capsule build, the extra lp_parm_int()
+		 * lookup aborts in early loadparm/talloc setup on NetBSD 6.
+		 * Keep the rpc_worker_main() defaults; we do not tune helper
+		 * worker counts on this appliance.
+		 */
+#endif
 
 		DBG_DEBUG("daemon=%s, num_workers=%d, idle_seconds=%d\n",
 			  daemon_config_name,
