diff --git a/lib/tdb/common/open.c b/lib/tdb/common/open.c
index 87312f7..fe57f99 100644
--- a/lib/tdb/common/open.c
+++ b/lib/tdb/common/open.c
@@ -854,6 +854,7 @@ static int tdb_reopen_internal(struct tdb_context *tdb, bool active_lock)
 #if !defined(LIBREPLACE_PREAD_NOT_REPLACED) || \
 	!defined(LIBREPLACE_PWRITE_NOT_REPLACED)
 	struct stat st;
+	int v;
 #endif
 
 	if (tdb->flags & TDB_INTERNAL) {
@@ -884,6 +885,22 @@ static int tdb_reopen_internal(struct tdb_context *tdb, bool active_lock)
 		TDB_LOG((tdb, TDB_DEBUG_FATAL, "tdb_reopen: open failed (%s)\n", strerror(errno)));
 		goto fail;
 	}
+	/*
+	 * tdb_open_ex() marks the initial fd close-on-exec. Reopen replaces
+	 * that fd, so restore the flag here instead of letting helper execs
+	 * inherit reopened database handles.
+	 */
+	v = fcntl(tdb->fd, F_GETFD, 0);
+	if (v == -1) {
+		TDB_LOG((tdb, TDB_DEBUG_WARNING,
+			 "tdb_reopen: WARNING could not read close-on-exec flags (%s)\n",
+			 strerror(errno)));
+	} else if (fcntl(tdb->fd, F_SETFD, v | FD_CLOEXEC) == -1) {
+		TDB_LOG((tdb, TDB_DEBUG_WARNING,
+			 "tdb_reopen: WARNING could not restore close-on-exec (%s)\n",
+			 strerror(errno)));
+	}
+
 	/*
 	 * We only use st.st_dev and st.st_ino from the raw fstat()
 	 * call, everything else needs to use tdb_fstat() in order
diff --git a/lib/tdb_wrap/tdb_wrap.c b/lib/tdb_wrap/tdb_wrap.c
index 49585aa..f4cf249 100644
--- a/lib/tdb_wrap/tdb_wrap.c
+++ b/lib/tdb_wrap/tdb_wrap.c
@@ -25,6 +25,10 @@
 #include "lib/util/debug.h"
 #include "tdb_wrap.h"
 
+#ifndef O_CLOEXEC
+#define O_CLOEXEC 0
+#endif
+
 /*
  Log tdb messages via DEBUG().
 */
