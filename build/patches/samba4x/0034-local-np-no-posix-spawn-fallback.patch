+#else
+static int samba_fork_exec(const char *path, char *const argv[], char *const envp[], pid_t *pid)
+{
+	pid_t child = fork();
+	if (child == -1) {
+		return errno;
+	}
+	if (child == 0) {
+		execve(path, argv, envp);
+		_exit(127);
+	}
+	*pid = child;
+	return 0;
+}
