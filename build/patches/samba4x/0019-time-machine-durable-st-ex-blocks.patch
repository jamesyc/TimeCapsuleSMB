+			  "stat_ex.%s differs: "
+			  "cookie:%llu != stat:%llu, "
+			  "allowing durable reconnect on Time Capsule build\n",
+			  fsp_str_dbg(fsp),
+			  "st_ex_blocks",
+			  (unsigned long long)cookie_st->st_ex_blocks,
+			  (unsigned long long)fsp_st->st_ex_blocks));
 	}
 
 	if (cookie_st->st_ex_flags != fsp_st->st_ex_flags) {
