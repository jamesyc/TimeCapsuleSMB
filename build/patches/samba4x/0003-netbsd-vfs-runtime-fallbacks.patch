+#ifdef TC_SAMBA4X_NETBSD4_COMPAT
+static DIR *tc_netbsd_fdopendir_compat(files_struct *fsp)
+{
+	DIR *result = NULL;
+	int dir_fd = -1;
+	int fd = fsp_get_io_fd(fsp);
+	int saved_errno = 0;
+
+	if (fd == -1 ||
+	    fsp->fsp_name == NULL ||
+	    fsp->fsp_name->base_name == NULL)
+	{
+		errno = EINVAL;
+		return NULL;
+	}
+
+	result = opendir(fsp->fsp_name->base_name);
+	if (result != NULL) {
+		dir_fd = dirfd(result);
+		if (dir_fd == -1) {
+			saved_errno = errno;
+			closedir(result);
+			errno = saved_errno;
+			return NULL;
+		}
+		if (dir_fd != fd && close(fd) == -1) {
+			saved_errno = errno;
+			closedir(result);
+			errno = saved_errno;
+			return NULL;
+		}
+		if (dir_fd != fd) {
+			fsp_set_fd(fsp, -1);
+			fsp_set_fd(fsp, dir_fd);
+		}
+	}
+
+	return result;
+}
+#endif
