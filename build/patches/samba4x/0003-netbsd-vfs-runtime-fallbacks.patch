+#ifdef TC_SAMBA4X_VFS_AT_PATH_COMPAT
+/*
+ * Time Capsule runtime kernels are older than the NetBSD SDKs used to build
+ * Samba. The NetBSD 6 appliance binary is built against NetBSD 7 headers, and
+ * NetBSD 4 lacks the same *at syscall family, so source3 can see *at/openat2
+ * support at compile time that is missing on-device. Use path-aware fallbacks
+ * for every appliance target.
+ *
+ * Do not emulate relative dirfd operations in lib/replace: a raw fd is not
+ * enough to reconstruct a share-relative path safely. The default VFS layer
+ * still has both dirfsp and smb_filename, so it can use Samba's own
+ * full_path_from_dirfsp_at_basename() helper and call older NetBSD syscalls.
+ */
+static char *tc_netbsd_at_path(TALLOC_CTX *mem_ctx,
+				const struct files_struct *dirfsp,
+				const struct smb_filename *smb_fname)
+{
+	char *path = NULL;
+
+	if (smb_fname == NULL ||
+	    smb_fname->base_name == NULL)
+	{
+		errno = EINVAL;
+		return NULL;
+	}
+
+	if (dirfsp == NULL) {
+		if (smb_fname->base_name[0] != '/') {
+			errno = EINVAL;
+			return NULL;
+		}
+		path = talloc_strdup(mem_ctx, smb_fname->base_name);
+		if (path == NULL) {
+			errno = ENOMEM;
+		}
+		return path;
+	}
+
+	path = full_path_from_dirfsp_at_basename(mem_ctx,
+						 dirfsp,
+						 smb_fname->base_name);
+	if (path == NULL) {
+		errno = ENOMEM;
+	}
+	return path;
+}
+
+static int tc_netbsd_validate_opened_directory(files_struct *fsp,
+					       int fd,
+					       int flags)
+{
+	SMB_STRUCT_STAT sbuf;
+	int ret;
+
+	if (fd == -1 ||
+	    (!fsp->fsp_flags.is_directory && (flags & O_DIRECTORY) == 0))
+	{
+		return fd;
+	}
+
+	ret = sys_fstat(fd,
+			&sbuf,
+			lp_fake_directory_create_times(SNUM(fsp->conn)));
+	if (ret != 0) {
+		int err = errno;
+		close(fd);
+		errno = err;
+		return -1;
+	}
+	if (!S_ISDIR(sbuf.st_ex_mode)) {
+		close(fd);
+		errno = ENOTDIR;
+		return -1;
+	}
+	return fd;
+}
+#endif
