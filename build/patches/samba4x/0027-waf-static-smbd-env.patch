index 3aa1c91..1bc9766 100644
--- a/buildtools/wafsamba/wafsamba.py
+++ b/buildtools/wafsamba/wafsamba.py
@@ -446,6 +446,24 @@ Build.BuildContext.SAMBA_LIBRARY = SAMBA_LIBRARY
 
 
 #################################################################
+def APPLY_SMBD_STATIC_ENV(bld, taskgen):
+    # Time Capsule runs smbd from a tiny RAM disk. Keep the deployed binary
+    # fully static and apply the static link flags only to smbd; external
+    # DCE-RPC helper binaries are intentionally not shipped because executing
+    # them from the HFS data disk is unsafe if Apple firmware unmounts it.
+    if getattr(taskgen, 'target', None) != 'smbd/smbd':
+        return
+    static_linkflags = TO_LIST(getattr(bld.env, 'SMBD_STATIC_LINKFLAGS', []))
+    static_ldflags = TO_LIST(getattr(bld.env, 'SMBD_STATIC_LDFLAGS', []))
+    if not static_linkflags and not static_ldflags:
+        return
+    taskgen.env = taskgen.env.derive()
+    taskgen.env.LINKFLAGS = static_linkflags
+    taskgen.env.LDFLAGS = static_ldflags
+    taskgen.env.LIBPATH = TO_LIST(getattr(bld.env, 'SMBD_STATIC_LIBPATH', []))
+    taskgen.env.SHLIB_MARKER = getattr(bld.env, 'SMBD_STATIC_SHLIB_MARKER', '')
+    taskgen.env.FULLSTATIC_MARKER = getattr(bld.env, 'SMBD_STATIC_FULLSTATIC_MARKER', '-static')
+
 def SAMBA_BINARY(bld, binname, source,
                  deps='',
                  includes='',
@@ -570,6 +588,7 @@ def SAMBA_BINARY(bld, binname, source,
         samba_use_hostcc = use_hostcc
         )
     APPLY_HOSTCC_ENV(bld, t)
+    APPLY_SMBD_STATIC_ENV(bld, t)
 
     if manpages is not None and 'XSLTPROC_MANPAGES' in bld.env and bld.env['XSLTPROC_MANPAGES']:
         bld.MANPAGES(manpages, install)
