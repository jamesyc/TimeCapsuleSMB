 #endif
 
 	if (tdb->flags & TDB_INTERNAL) {
@@ -884,6 +885,16 @@ static int tdb_reopen_internal(struct tdb_context *tdb, bool active_lock)
 		TDB_LOG((tdb, TDB_DEBUG_FATAL, "tdb_reopen: open failed (%s)\n", strerror(errno)));
 		goto fail;
 	}
+	/*
+	 * tdb_open_ex() marks the initial fd close-on-exec. Reopen replaces
+	 * that fd, so restore the flag here instead of letting helper execs
+	 * inherit reopened database handles.
+	 */
+	v = fcntl(tdb->fd, F_GETFD, 0);
+	if (v != -1) {
+		fcntl(tdb->fd, F_SETFD, v | FD_CLOEXEC);
+	}
+
